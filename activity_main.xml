<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ========== HEADER ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛡️ Penjaga Adek"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v4 — WA + Instagram → Telegram"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- ========== STATUS ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STATUS"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:text="Memuat..."
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="#1A1A1A"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvQueue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:text="📤 Antrian pesan: kosong"
            android:textSize="12sp"
            android:textColor="#888888"
            android:background="#1A1A1A"
            android:layout_marginBottom="20dp" />

        <!-- ========== TELEGRAM CONFIG ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="KONFIGURASI TELEGRAM"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etBotToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Bot Token (dari @BotFather)"
            android:inputType="textNoSuggestions"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="#1A1A1A"
            android:padding="14dp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etChatId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Chat ID (misal: -100xxxxxxx)"
            android:inputType="textNoSuggestions"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="#1A1A1A"
            android:padding="14dp"
            android:layout_marginBottom="20dp" />

        <!-- ========== SWITCHES ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PENGATURAN PEMANTAUAN"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="4dp" />

        <!-- Switch: Aktif -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1A1A1A"
            android:padding="14dp"
            android:layout_marginBottom="2dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Aktifkan Pemantauan"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
            <Switch android:id="@+id/switchActive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- Switch: Nomor tidak dikenal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1A1A1A"
            android:padding="14dp"
            android:layout_marginBottom="2dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hanya Nomor Tidak Dikenal"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Abaikan pesan dari kontak tersimpan"
                    android:textColor="#666666"
                    android:textSize="11sp" />
            </LinearLayout>
            <Switch android:id="@+id/switchUnknownOnly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Switch: Instagram -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1A1A1A"
            android:padding="14dp"
            android:layout_marginBottom="20dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📸 Pantau Instagram"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DM dan notifikasi Instagram ikut dikirim"
                    android:textColor="#666666"
                    android:textSize="11sp" />
            </LinearLayout>
            <Switch android:id="@+id/switchInstagram"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- ========== BUTTONS ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AKSI"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="💾  Simpan Pengaturan"
            android:backgroundTint="#25D366"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnPermission"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🔔  Beri Izin Notifikasi"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnBattery"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🔋  Matikan Optimasi Baterai"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnRestartService"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🔄  Restart Service"
            android:backgroundTint="#9C27B0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnTest"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="📤  Test Kirim Telegram"
            android:backgroundTint="#607D8B"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- ========== FOOTER INFO ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ℹ️ Urutan setup:\n1. Isi Token &amp; Chat ID → Simpan\n2. Beri Izin Notifikasi → aktifkan 'Penjaga Adek'\n3. Matikan Optimasi Baterai → izinkan\n4. Test kirim untuk memastikan OK\n\n💡 Jika notif tiba-tiba berhenti → Restart Service\n💡 Di Xiaomi/OPPO/Samsung: aktifkan Autostart &amp; kunci app di Recent"
            android:textColor="#555555"
            android:textSize="12sp"
            android:padding="14dp"
            android:background="#1A1A1A"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
